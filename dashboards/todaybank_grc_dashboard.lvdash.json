{
  "displayName": "TodayBank GRC Operations Hub",
  "description": "Risk Officer one-screen view across AML, Fair Lending, KYC, and Complaints.",
  "datasets": [
    {
      "name": "kpi_open_aml_alerts",
      "displayName": "Open AML Alerts (30d)",
      "queryLines": [
        "SELECT COUNT(*) AS open_aml_alerts ",
        "FROM todaybank_grc_demo.gold.aml_alerts ",
        "WHERE transaction_date > current_date() - INTERVAL 30 DAYS"
      ]
    },
    {
      "name": "kpi_high_kyc",
      "displayName": "High KYC Customers",
      "queryLines": [
        "SELECT COUNT(*) AS high_kyc_customers ",
        "FROM todaybank_grc_demo.silver.customers ",
        "WHERE kyc_risk_tier = 'High'"
      ]
    },
    {
      "name": "kpi_approval_rate",
      "displayName": "HMDA Approval Rate (Overall)",
      "queryLines": [
        "SELECT ROUND(SUM(approved_count) / SUM(application_count) * 100, 1) AS overall_approval_rate_pct ",
        "FROM todaybank_grc_demo.gold.hmda_summary"
      ]
    },
    {
      "name": "kpi_complaints_month",
      "displayName": "Complaints This Month",
      "queryLines": [
        "SELECT COUNT(*) AS complaints_this_month ",
        "FROM todaybank_grc_demo.silver.complaints_classified ",
        "WHERE DATE_TRUNC('month', received_date) = DATE_TRUNC('month', current_date())"
      ]
    },
    {
      "name": "aml_alerts_by_type",
      "displayName": "AML Alerts by Type (90d)",
      "queryLines": [
        "SELECT alert_type, COUNT(*) AS alert_count, SUM(structuring_total) AS total_amount_usd ",
        "FROM todaybank_grc_demo.gold.aml_alerts ",
        "WHERE transaction_date > current_date() - INTERVAL 90 DAYS ",
        "GROUP BY alert_type ORDER BY alert_count DESC"
      ]
    },
    {
      "name": "fair_lending_heatmap",
      "displayName": "Fair Lending Approval Rate by Demographic",
      "queryLines": [
        "SELECT race, ethnicity, gender, loan_purpose, application_count, ",
        "  ROUND(approval_rate * 100, 1) AS approval_rate_pct ",
        "FROM todaybank_grc_demo.gold.hmda_summary ",
        "WHERE application_count >= 20 ",
        "ORDER BY approval_rate_pct ASC"
      ]
    },
    {
      "name": "complaint_themes_ts",
      "displayName": "Complaint Volume by Theme",
      "queryLines": [
        "SELECT month, theme, SUM(complaint_count) AS complaints ",
        "FROM todaybank_grc_demo.gold.complaint_themes ",
        "GROUP BY month, theme ORDER BY month, theme"
      ]
    },
    {
      "name": "top_risk_customers",
      "displayName": "Top Risk Customers",
      "queryLines": [
        "SELECT customer_id, full_name, state, kyc_risk_tier, aml_alert_count, ",
        "  aml_alert_total_usd, complaint_count, ROUND(balance_usd, 0) AS balance_usd ",
        "FROM todaybank_grc_demo.gold.customer_risk_360 ",
        "WHERE aml_alert_count > 0 OR (kyc_risk_tier = 'High' AND complaint_count >= 2) ",
        "ORDER BY aml_alert_total_usd DESC NULLS LAST, complaint_count DESC LIMIT 25"
      ]
    },
    {
      "name": "pep_matches",
      "displayName": "KYC PEP Matches",
      "queryLines": [
        "SELECT kyc_doc_id, full_name, document_date, occupation, source_of_funds, pep_status ",
        "FROM todaybank_grc_demo.gold.kyc_pep_matches ORDER BY document_date DESC"
      ]
    },
    {
      "name": "risk_score_distribution",
      "displayName": "AML Model Risk Score Distribution",
      "queryLines": [
        "SELECT CASE WHEN risk_score < 0.25 THEN '0.00-0.24' ",
        "  WHEN risk_score < 0.50 THEN '0.25-0.49' ",
        "  WHEN risk_score < 0.75 THEN '0.50-0.74' ",
        "  ELSE '0.75-1.00' END AS risk_bucket, ",
        "COUNT(*) AS customer_count ",
        "FROM todaybank_grc_demo.gold.aml_risk_scores ",
        "GROUP BY risk_bucket ORDER BY risk_bucket"
      ]
    }
  ],
